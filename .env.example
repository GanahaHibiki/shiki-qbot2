# QQ Bot 环境变量配置

# QQ 账号 (必填)
QQ_ACCOUNT=

# 复读概率 (0-100, 默认 5)
REPEAT_PROBABILITY=5

# AI回复概率 (0-100, 默认 10)
AI_REPLY_PROBABILITY=10

# AI 模型 (默认 deepseek-ai/DeepSeek-V3)
AI_MODEL=deepseek-ai/DeepSeek-V3

# AI 系统提示词 (可选，用于自定义AI人格)
AI_SYSTEM_PROMPT=

# AI API Key (SiliconFlow, 可选)
AI_API_KEY=

# HTTP/HTTPS 代理 (可选)
HTTP_PROXY=
HTTPS_PROXY=

# 日志级别 (DEBUG/INFO/WARNING/ERROR, 默认 INFO)
LOG_LEVEL=INFO
